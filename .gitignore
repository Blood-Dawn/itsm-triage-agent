# Model artifacts
# Ignore training checkpoints (large, not needed at inference)
models/finetuned/distilbert-lora/checkpoint-*/
checkpoints/

# Ignore loose weight files at top level
# (The adapter directory below is explicitly allowed)
*.pth
*.bin

# ── Adapter weights (include these — only ~620KB, needed for HF Spaces) ──────
# We un-ignore the specific adapter directory and its files.
# The gitignore pattern: ignore finetuned/* but allow the adapter subdir.
models/finetuned/*
!models/finetuned/distilbert-lora/
models/finetuned/distilbert-lora/*
!models/finetuned/distilbert-lora/adapter/
models/finetuned/distilbert-lora/adapter/*
!models/finetuned/distilbert-lora/adapter/*.json
!models/finetuned/distilbert-lora/adapter/*.safetensors
!models/finetuned/distilbert-lora/adapter/*.pt
!models/finetuned/distilbert-lora/adapter/README.md

# Logs
*.log
logs/

# Build artifacts
artifacts/
dist/
build/

